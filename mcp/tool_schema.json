{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/ai-governance/tool-contract.schema.json",
  "title": "AI Tool Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "tool_name",
    "tool",
    "description",
    "allowed_modes",
    "risk_level",
    "policy_refs",
    "human_approval",
    "preconditions",
    "required_evidence",
    "forbidden_actions",
    "input_schema",
    "output_schema"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "tool_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "tool": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "allowed_modes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "explore",
          "safe-change",
          "restricted"
        ]
      },
      "uniqueItems": true
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "moderate",
        "high",
        "critical"
      ]
    },
    "policy_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "human_approval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "policy"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "policy": {
          "type": "string",
          "enum": [
            "never",
            "required_if_core_module",
            "required_if_destructive",
            "always"
          ]
        }
      }
    },
    "preconditions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbidden_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "input_schema": {
      "type": "object"
    },
    "output_schema": {
      "type": "object"
    },
    "postconditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
