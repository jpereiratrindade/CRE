{
  "contract_version": "v1.0.0",
  "tool_name": "modify_code",
  "tool": "modify_code",
  "description": "Aplica mudancas em codigo-fonte respeitando testes, politicas e modo operacional.",
  "allowed_modes": [
    "safe-change",
    "restricted"
  ],
  "risk_level": "high",
  "policy_refs": [
    "policies/ai_usage_policy.md",
    "policies/code_generation_rules.md",
    "policies/review_policy.md",
    "policies/safety_constraints.md"
  ],
  "human_approval": {
    "required": true,
    "policy": "required_if_core_module"
  },
  "preconditions": [
    "workspace_resolved",
    "affected_files_identified",
    "impact_scope_declared"
  ],
  "required_evidence": [
    "task_id",
    "human_owner",
    "tests_pass",
    "diff_reviewed",
    "policy_compliance_checked"
  ],
  "forbidden_actions": [
    "disable_tests",
    "reduce_validation_scope",
    "edit_unowned_context_without_contract",
    "perform_destructive_reset"
  ],
  "input_schema": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "target_files",
      "change_reason",
      "expected_outcome"
    ],
    "properties": {
      "target_files": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string"
        }
      },
      "change_reason": {
        "type": "string",
        "minLength": 1
      },
      "expected_outcome": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "output_schema": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "changed_files",
      "summary",
      "evidence"
    ],
    "properties": {
      "changed_files": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "summary": {
        "type": "string"
      },
      "evidence": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    }
  },
  "postconditions": [
    "changes_are_traceable",
    "required_evidence_is_reported"
  ]
}
